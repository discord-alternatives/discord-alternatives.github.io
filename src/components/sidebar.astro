---

<aside class="s-sidebar" id="sidebar">
    <div class="s-inner">
        {
            sections.map((section) => (
                <section class="s-section">
                    <h2 class="s-label">{section.label}</h2>

                    {section.selects?.map((f) => (
                        <div class="f-row">
                            <label class="f-lbl" for={"f-" + f.key}>
                                {f.label}
                            </label>
                            <select
                                class="f-sel"
                                id={"f-" + f.key}
                                data-filter={f.key}
                            >
                                <option value="">Any</option>
                                {f.options.map((o) => (
                                    <option value={o.value}>{o.label}</option>
                                ))}
                            </select>
                        </div>
                    ))}

                    {section.toggles?.length ? (
                        <div class="t-grid">
                            {section.toggles.map((f) => (
                                <div class="t-row">
                                    <span class="f-lbl">{f.label}</span>
                                    <button
                                        class="toggle"
                                        id={"t-" + f.key}
                                        data-filter={f.key}
                                        role="switch"
                                        aria-checked="false"
                                    />
                                </div>
                            ))}
                        </div>
                    ) : null}
                </section>
            ))
        }

        <button class="reset-btn" id="reset-btn">
            <i class="ti ti-refresh" aria-hidden="true"></i> Reset all
        </button>
    </div>
</aside>
