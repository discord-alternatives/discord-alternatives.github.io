---
interface SelectFilter {
    type: "select";
    key: string;
    label: string;
    options: { value: string; label: string }[];
}
interface ToggleFilter {
    type: "toggle";
    key: string;
    label: string;
}
interface Section {
    label: string;
    selects?: SelectFilter[];
    toggles?: ToggleFilter[];
}

function sel(
    key: string,
    label: string,
    ...opts: [string, string][]
): SelectFilter {
    return {
        type: "select",
        key,
        label,
        options: opts.map(([v, l]) => ({ value: v, label: l })),
    };
}
function tog(key: string, label: string): ToggleFilter {
    return { type: "toggle", key, label };
}

