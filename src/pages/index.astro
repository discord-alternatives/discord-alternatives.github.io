---
import platforms from "../../data/platforms.json";
import discord from "../../data/discord.json";
import PlatformRow from "../components/platform-row.astro";
import Sidebar from "../components/sidebar.astro";
import "../styles/global.css";

const discordEntry = { ...discord, id: "discord", icon: "🎮" };
const platformEntries = (platforms as any[]).map((p) => ({
    ...p,
    id: p.name.toLowerCase().replace(/[\s()]/g, "-"),
}));
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Discord Alternatives</title>
        <link rel="icon" href="/favicon.ico" />
        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css"
        />
    </head>
    <body>
        <div class="app">
            <header class="topbar">
                <span class="topbar-title">Discord Alternatives</span>
                <span class="topbar-dot">•</span>
                <span id="top-summary"
                    >Compare Discord with alternative platforms</span
                >
                <span class="topbar-dot">•</span>
                <a
                    class="top-summary"
                    href="https://github.com/stribes/discord-alternatives"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <i class="ti ti-brand-github top-summary" aria-hidden="true"
                    ></i>
                    Add Your Alternative & Source Code
                </a>
            </header>

            <div class="body">
                <Sidebar />

                <main class="main">
                    <div class="comp-section">
                        <div class="section-lbl">Comparison baseline</div>
                        <PlatformRow
                            platform={discordEntry}
                            isComparison={true}
                        />
                    </div>
                    <div class="alts-header">
                        <div class="section-lbl" id="alts-label">
                            Alternatives
                        </div>
                    </div>
                    <div class="alts-list" id="main-list">
                        {
                            platformEntries.map((p) => (
                                <PlatformRow platform={p} />
                            ))
                        }
                    </div>
                </main>
            </div>
        </div>

        <div id="notes-modal" class="notes-modal" hidden>
            <div class="notes-modal-backdrop"></div>
            <div class="notes-modal-content">
                <div class="notes-modal-header">
                    <h2 id="notes-modal-title">Notes</h2>
                    <button
                        id="notes-modal-close"
                        class="notes-modal-close"
                        aria-label="Close"
                    >
                        <i class="ti ti-x" aria-hidden="true"></i>
                    </button>
                </div>
                <div class="notes-modal-body">
                    <div id="notes-modal-text" class="notes-modal-text"></div>
                </div>
            </div>
        </div>

        <script src="../scripts/app.ts"></script>
    </body>
</html>
